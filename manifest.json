{
  "manifest_version": 3,
  "name": "Bokio Invoice Helper",
  "description": "Defaults Bokio invoices to PDF & link so the wrong delivery method does not become a late-payment surprise.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.bokio.se/*/invoicing/invoices/edit/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
